# Octopus Energy
# API key from https://octopus.energy/dashboard/new/accounts/personal-details/api-access
OCTOPUS_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# Hypervolt — same email + password used to log into the mobile app
HYPERVOLT_EMAIL=you@example.com
HYPERVOLT_PASSWORD=

# Growatt — API token from ShinePhone (Me → API Token)
GROWATT_API_TOKEN=
# Inverter serial number (visible in ShinePhone or on the unit sticker)
GROWATT_DEVICE_SN=

# Cheap-window override (Europe/London local time, 24h)
CHEAP_WINDOW_START=23:30s
CHEAP_WINDOW_END=05:30

# AC-charge configuration
CHARGE_POWER_PERCENT=100
CHARGE_STOP_SOC=100

# Operational tuning
LOG_LEVEL=INFO
OCTOPUS_POLL_SECONDS=120
DECISION_INTERVAL_SECONDS=60
GROWATT_KEEPALIVE_SECONDS=600
GROWATT_SLOT_LENGTH_SECONDS=900
